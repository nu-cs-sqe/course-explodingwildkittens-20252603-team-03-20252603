<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>

    <!-- Max line length: 120 characters (URLs and imports are exempt) -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
    </module>

    <module name="TreeWalker">

        <!-- Indent must use tab characters -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="^\t* "/>
            <property name="message" value="Indent must use tab characters"/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- ===== FUNCTIONS / METHODS (Clean Code Ch. 3) ===== -->

        <!-- Methods should be small: flag if over 20 lines -->
        <module name="MethodLength">
            <property name="max" value="20"/>
            <property name="countEmpty" value="false"/>
            <message key="maxLen.method" value="Method length is {0} lines (max 20). Methods should do one thing only."/>
        </module>

        <!-- Limit parameters: max 3, flag 4+; GameController constructor is an intentional exception (4 params per design.puml) -->
        <module name="ParameterNumber">
            <property name="max" value="4"/>
            <message key="maxParam" value="Method has {0} parameters (max 4). Consider grouping into a class."/>
        </module>

        <!-- ===== CLASSES (Clean Code Ch. 10) ===== -->

        <!-- Only one top-level class per file -->
        <module name="OneTopLevelClass"/>

        <!-- ===== ERROR HANDLING (Clean Code Ch. 7) ===== -->

        <!-- Empty catch blocks are not allowed -->
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="expected|ignore"/>
            <message key="catch.block.empty" value="Empty catch block. Handle the exception or document why it is safe to ignore."/>
        </module>

        <!-- ===== IMPORTS ===== -->

        <!-- No unused imports -->
        <module name="UnusedImports"/>

        <!-- No redundant imports -->
        <module name="RedundantImport"/>

        <!-- ===== BEST PRACTICES ===== -->

        <!-- No magic numbers (use named constants) -->
        <module name="MagicNumber">
            <property name="ignoreNumbers" value="-1, 0, 1, 2"/>
            <property name="ignoreAnnotation" value="true"/>
            <message key="magic.number" value="Magic number ''{0}'' should be defined as a named constant."/>
        </module>

        <!-- equals() and hashCode() must be overridden together -->
        <module name="EqualsHashCode">
            <message key="equals.noHashCode" value="Class overrides equals() but not hashCode() — both must be overridden together."/>
        </module>

        <!-- Simplify boolean expressions -->
        <module name="SimplifyBooleanExpression"/>
        <module name="SimplifyBooleanReturn"/>

    </module>

</module>